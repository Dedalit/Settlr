---
export const prerender = false;
import '@/styles/global.css'
import { createClient } from "@/lib/supabase"
import Layout from '@/layouts/Layout.astro';

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies })
const { data: { session } } = await supabase.auth.getSession();
---

<Layout>
  <div class="lavalamp-bg min-h-screen antialiased text-white overflow-hidden relative flex items-center justify-center">
    <div class="relative w-full max-w-md p-6 z-30 mx-auto">
      <div class="w-full bg-[#110B3B]/60 backdrop-blur-xl border-0 p-8 rounded-3xl shadow-2xl text-white">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-black tracking-widest uppercase">SETTLR</h2>
          <p id="status-text" class="text-xs text-purple-200/80 mt-2">Checking...</p>
        </div>

        <form id="update-form" class="space-y-4 px-1 hidden">
          <div>
            <label for="password" class="block text-xs font-medium text-purple-100 mb-1">New Password</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              class="w-full bg-white/10 border border-white/20 rounded-md px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-purple-400 h-9 text-sm"
            />
          </div>

          <div id="msg" class="hidden text-xs font-medium p-2 rounded-md border"></div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-white text-[#110B3B] hover:bg-purple-100 font-semibold shadow-lg h-9 text-sm rounded-md transition"
          >
            Update Password
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<!-- Script per gestire l'hash di Supabase (token di recupero) -->
<script define:vars={{ hasSession: !!session }}>
      const form = document.getElementById('update-form');
      const statusText = document.getElementById('status-text');
      const msg = document.getElementById('msg');
      const btn = document.getElementById('submit-btn');

      // Se c'è già una sessione attiva o se siamo atterrati con un token hash valido
      if (hasSession || window.location.hash.includes('type=recovery')) {
        form.classList.remove('hidden');
        statusText.textContent = 'Enter your new password';
      } else {
        statusText.textContent = 'Link non valido o scaduto. Reindirizzamento...';
        setTimeout(() => {
          window.location.href = '/auth/signin';
        }, 2000);
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = 'Updating...';
        msg.classList.add('hidden');

        const formData = new FormData(form);
        const password = formData.get('password');

        try {
          const res = await fetch('/api/auth/update-password', {
            method: 'POST',
            body: JSON.stringify({ password }),
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' }
          });
          const data = await res.json();

          msg.classList.remove('hidden');
          if (res.ok && data.success) {
            msg.className = 'text-xs font-medium p-2 rounded-md border text-emerald-300 bg-emerald-950/40 border-emerald-500/30';
            msg.textContent = 'Password aggiornata con successo! Reindirizzamento...';
            setTimeout(() => { window.location.href = '/dashboard'; }, 1500);
          } else {
            msg.className = 'text-xs font-medium p-2 rounded-md border text-red-400 bg-red-950/40 border-red-500/30';
            msg.textContent = data.message || "Errore durante l'aggiornamento.";
            btn.disabled = false;
            btn.textContent = 'Update Password';
          }
        } catch (err) {
          msg.classList.remove('hidden');
          msg.className = 'text-xs font-medium p-2 rounded-md border text-red-400 bg-red-950/40 border-red-500/30';
          msg.textContent = 'Errore di rete. Riprova.';
          btn.disabled = false;
          btn.textContent = 'Update Password';
        }
      });
    </script>