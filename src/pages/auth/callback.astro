---
import { createClient } from "../../lib/supabase";
import type { EmailOtpType } from "@supabase/supabase-js";
import Layout from "@/layouts/Layout.astro";
import FallingReceipts from "@/components/FallingReceipts.astro";

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const requestUrl = new URL(Astro.request.url);
const token_hash = requestUrl.searchParams.get('token_hash');
const type = requestUrl.searchParams.get('type') as EmailOtpType | null;

if (token_hash && type) {
  const { error } = await supabase.auth.verifyOtp({
    token_hash,
    type,
  });

  if (!error) {
    return Astro.redirect("/dashboard");
  }
}

return Astro.redirect("/auth/signin");
---

<Layout title="Email Confirm">
  <FallingReceipts>
    <div class="relative w-full max-w-md p-6 z-30 mx-auto">
      <div class="w-full bg-[#110B3B]/60 backdrop-blur-xl border-0 p-8 rounded-3xl shadow-2xl text-white">
        <div class="text-center mb-6">
          <h2 class="text-2xl font-black tracking-widest uppercase">SETTLR</h2>
          <p id="status-text" class="text-xs text-purple-200/80 mt-2">Confirming your email...</p>
        </div>
      </div>
    </div>
  </FallingReceipts>
</Layout>