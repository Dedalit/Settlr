---
import { createClient } from "@/lib/supabase"
import { SignInForm } from "@/components/signin-form"
import FallingReceipts from '@/components/FallingReceipts.astro'
import Layout from '@/layouts/Layout.astro'

// Server-side authentication check
const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
})

const { data } = await supabase.auth.getUser()

if (data?.user) {
  return Astro.redirect("/dashboard")
}
---

<Layout>
  <FallingReceipts>
    <div class="relative w-full max-w-md p-6 z-30 mx-auto">
      <div class="w-full bg-[#110B3B]/60 backdrop-blur-xl border border-white/20 p-8 rounded-3xl shadow-2xl">
        <div class="text-center mb-6">
          <a href="/" class="inline-block">
            <h2 class="text-2xl font-black tracking-widest text-transparent bg-clip-text bg-linear-to-b from-white via-white/95 to-purple-200/80 uppercase">
              SETTLR
            </h2>
          </a>
        </div>
        
        <SignInForm client:load onSuccess={() => window.location.href = "/dashboard"} />
      </div>
    </div>
  </FallingReceipts>
</Layout>