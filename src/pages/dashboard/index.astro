---
export const prerender = false;
import '@/styles/global.css';
import { createClient } from "@/lib/supabase";
import DashboardLayout from "@/components/dashboard-layout"; // Assicurati che il percorso corrisponda
import Layout from '@/layouts/Layout.astro';

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { user }, error } = await supabase.auth.getUser();

if (error || !user) {
  return Astro.redirect("/auth/signin");
}

const userEmail = user.email || "email@sconosciuta.com";
const customUsername = user.user_metadata?.username;
const firstName = user.user_metadata?.first_name || "";
const lastName = user.user_metadata?.last_name || "";

let userName = userEmail.split('@')[0];
if (customUsername && customUsername.trim() !== "") {
  userName = customUsername;
} else if (firstName || lastName) {
  userName = `${firstName} ${lastName}`.trim();
}

const userInitials = userName
  .split(" ")
  .map((n: string) => n[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);
---

<Layout>
  <div class="bg-[#0a071e] text-white antialiased min-h-screen">
    
    <!-- NOTA FONDAMENTALE: client:only="react" impedisce l'SSR e fa partire tutto correttamente sul client -->
    <DashboardLayout 
      client:only="react"
      userName={userName} 
      userEmail={userEmail} 
      userInitials={userInitials}
    >
      <div class="max-w-6xl w-full mx-auto space-y-6">
        
        <!-- Header welcome -->
        <div class="bg-[#110B3B]/60 backdrop-blur-xl border border-white/10 rounded-3xl p-6 shadow-2xl flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <div class="size-16 rounded-full bg-linear-to-tr from-purple-600 to-indigo-600 flex items-center justify-center text-xl font-bold text-white shadow-lg">
              {userInitials}
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">Welcome, {userName}!</h2>
              <p class="text-xs text-purple-200/70 mt-0.5">{userEmail}</p>
            </div>
          </div>
          
          <div class="flex items-center gap-3 w-full md:w-auto">
            <button class="flex-1 md:flex-none bg-orange-600 hover:bg-orange-500 text-white font-semibold px-4 py-2 rounded-xl text-sm shadow-lg transition">
              Add a bill
            </button>
            <button class="flex-1 md:flex-none bg-emerald-600 hover:bg-emerald-500 text-white font-semibold px-4 py-2 rounded-xl text-sm shadow-lg transition">
              Settle up
            </button>
          </div>
        </div>

        <!-- Box expenses -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="h-36 rounded-3xl bg-[#110B3B]/40 backdrop-blur-xl border border-white/10 p-6 flex flex-col justify-between">
            <span class="text-xs text-purple-200/60 uppercase tracking-wider font-semibold">Total Expenses</span>
            <span class="text-2xl font-black text-white">€0.00</span>
          </div>
          <div class="h-36 rounded-3xl bg-[#110B3B]/40 backdrop-blur-xl border border-white/10 p-6 flex flex-col justify-between">
            <span class="text-xs text-purple-200/60 uppercase tracking-wider font-semibold">They owe you</span>
            <span class="text-2xl font-black text-emerald-400">€0.00</span>
          </div>
          <div class="h-36 rounded-3xl bg-[#110B3B]/40 backdrop-blur-xl border border-white/10 p-6 flex flex-col justify-between">
            <span class="text-xs text-purple-200/60 uppercase tracking-wider font-semibold">You owe</span>
            <span class="text-2xl font-black text-orange-400">€0.00</span>
          </div>
        </div>

        <!-- Transactions -->
        <div class="h-96 rounded-3xl bg-[#110B3B]/40 backdrop-blur-xl border border-white/10 p-6 flex flex-col items-center justify-center text-center">
          <p class="text-sm font-semibold text-white">No transactions yet</p>
          <p class="text-xs text-purple-200/60 mt-1">Non appena collegherete il backend, qui comparirà la cronologia delle transazioni.</p>
        </div>

      </div>
    </DashboardLayout>
  </div>
</Layout>

<script>
  window.addEventListener('pageshow', function (event) {
    if (event.persisted) {
      window.location.reload();
    }
  });
</script>
